{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Term Proxy",
  "version": "0.1.0",
  "identifier": "dev.ruoduan.term-proxy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Term Proxy",
        "width": 1080,
        "height": 720,
        "minWidth": 840,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
